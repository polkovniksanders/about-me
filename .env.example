# Resend API Key (получить на resend.com)
RESEND_API_KEY=re_REPLACE_ME

# Email владельца сайта (куда приходят заявки)
OWNER_EMAIL=your@email.com

# Email отправителя (должен быть верифицирован в Resend)
FROM_EMAIL=noreply@yourdomain.com

# Разрешённый origin для CORS (ваш Vercel URL)
ALLOWED_ORIGIN=https://yourproject.vercel.app
